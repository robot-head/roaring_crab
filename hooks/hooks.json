{
  "hooks": {
    "SessionStart": [
      { "hooks": [
        { "type": "command", "command": "node", "args": ["${CLAUDE_PLUGIN_ROOT}/bin/launcher.js", "SessionStart"] }
      ] }
    ],
    "SessionEnd": [
      { "hooks": [
        { "type": "command", "command": "node", "args": ["${CLAUDE_PLUGIN_ROOT}/bin/launcher.js", "SessionEnd"] }
      ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [
        { "type": "command", "command": "node", "args": ["${CLAUDE_PLUGIN_ROOT}/bin/launcher.js", "UserPromptSubmit"] }
      ] }
